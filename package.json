{
  "name": "@benrasha/nest-generator",
  "version": "1.1.0",
  "description": "NestJS CLI util for generating project from the templates",
  "keywords": [
    "nestjs",
    "cli",
    "generator"
  ],
  "homepage": "https://github.com/ivvan-grishchenko/nestjs-generator",
  "bugs": {
    "url": "https://github.com/ivvan-grishchenko/nestjs-generator/issues"
  },
  "author": "Grishchenko, Ivan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivvan-grishchenko/nestjs-generator.git"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "nest-generator": "dist/main.js"
  },
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "prepare": "husky",
    "postinstall": "node scripts/patch-suites-doubles-vitest.mjs",
    "commit-msg": "commitlint -e",
    "pre-commit": "npm run lint:staged && npm run test"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@suites/di.nestjs": "^3.0.1",
    "@suites/doubles.vitest": "^3.0.1",
    "@suites/unit": "^3.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "nest-commander-testing": "^3.5.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": "eslint --cache \"{src,apps,libs,test}/**/*.ts\""
  }
}
